# Фиксируем конкретный минорный тег, а не "latest" — чтобы пересборка
# образа через месяц не подсунула неожиданно другую версию Python.
FROM python:3.12.7-slim

WORKDIR /app/src

# requirements.txt на этом шаге пуст (stdlib-only), но копируем и
# ставим заранее — когда появятся зависимости (шаг с поиском/LLM),
# слой с pip install будет кэшироваться отдельно от кода приложения.
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir --break-system-packages -r /app/requirements.txt

COPY src/ /app/src/

# Заранее создаём папку под SQLite — на случай локального запуска без
# примонтированного volume (например в Codespaces). На Railway сюда
# будет примонтирован настоящий Volume, поэтому эта папка не критична,
# но не помешает.
RUN mkdir -p /data

# Осознанно работаем от root, а не от отдельного непривилегированного
# пользователя: Railway монтирует Volume уже во время запуска
# контейнера (не во время сборки образа) и почти всегда — с правами
# root, так что непривилегированный пользователь не смог бы писать в
# него в любом случае без дополнительного entrypoint-скрипта с chown
# при каждом старте. Для личного бота в одном изолированном
# контейнере это разумный компромисс: реальная граница безопасности —
# сам контейнер (доступ к нему), а не разграничение прав внутри него.

CMD ["python", "main.py"]
