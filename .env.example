# Скопируйте в .env для локального запуска (или задайте эти же
# переменные в Railway → Variables). Не коммитьте настоящий .env.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Придумайте длинную случайную строку (например: openssl rand -hex 32)
# — Telegram будет присылать её в заголовке каждого webhook-запроса,
# так мы отличаем настоящие запросы от Telegram от чужих.
TELEGRAM_WEBHOOK_SECRET=

# Ваш personal chat_id в Telegram — только этому chat_id бот будет
# отвечать. Узнать: написать боту, посмотреть в логах контейнера
# (chat_id постороннего будет виден в WARNING-логе), либо через
# отдельного бота вроде @userinfobot.
OWNER_CHAT_ID=

# Путь для вебхука, по умолчанию /webhook — можно не менять.
TELEGRAM_WEBHOOK_PATH=/webhook

# Railway сам задаёт PORT — локально можно оставить как есть.
PORT=8080

# Нужен только для разового запуска scripts/set_webhook.py —
# публичный домен, который Railway выдаёт сервису (Settings → Networking).
PUBLIC_URL=

# Путь к файлу SQLite. На Railway: Settings -> Volumes -> Mount Path
# должен совпадать с папкой отсюда (например /data), иначе заметки и
# история диалога будут пропадать при каждом передеплое.
DB_PATH=/data/agent.db

# Сколько последних сообщений диалога держим "как есть", не сжимая.
HISTORY_KEEP_LAST=20

# Бюджет токенов (грубая оценка) на "живую" историю диалога — при
# превышении самая старая часть (кроме HISTORY_KEEP_LAST) сжимается.
HISTORY_TOKEN_BUDGET=3000

# ── LLM (OpenRouter, clavis.to или любой OpenAI-совместимый шлюз) ──
LLM_API_KEY=

# Базовый URL БЕЗ /chat/completions на конце.
#   OpenRouter: https://openrouter.ai/api/v1
#   clavis.to:  проверьте в личном кабинете/документации clavis.to —
#               на момент написания кода у меня нет подтверждённого
#               публичного адреса их API, поэтому не подставляю его
#               "на угад". Формат запроса стандартный OpenAI-совместимый,
#               так что после того как впишете верный URL, остальной
#               код трогать не нужно.
LLM_BASE_URL=https://openrouter.ai/api/v1

# Конкретный идентификатор модели у выбранного провайдера, например
# для OpenRouter: deepseek/deepseek-chat-v3-0324:free (проверьте
# актуальный список моделей в их каталоге — они меняются).
LLM_MODEL=

# Лимиты запросов к LLM в минуту / минимальный интервал между
# запросами (сек). Для OpenRouter :free-моделей 20/мин было
# актуально на момент написания кода — свериться с их документацией.
LLM_MAX_PER_MINUTE=20
LLM_MIN_INTERVAL=0

# ── Поиск (Keenable) ──
# Пусто = keyless-режим (более строгий лимит на стороне Keenable).
KEENABLE_API_KEY=

# ВАЖНО: у меня нет подтверждённой из первых рук спецификации REST API
# Keenable — значение ниже правдоподобное, но сверьтесь с реальной
# документацией/README проекта Keenable. Если формат отличается,
# правится только modules/search/service.py (функция _parse_response).
KEENABLE_BASE_URL=https://api.keenable.ai

# Ваше стартовое ограничение — не чаще 1 запроса в 0.5 секунды.
KEENABLE_MIN_INTERVAL=0.5
