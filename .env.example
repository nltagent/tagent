# Скопируйте в .env для локального запуска (или задайте эти же
# переменные в Railway → Variables). Не коммитьте настоящий .env.

# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Придумайте длинную случайную строку (например: openssl rand -hex 32)
# — Telegram будет присылать её в заголовке каждого webhook-запроса,
# так мы отличаем настоящие запросы от Telegram от чужих.
TELEGRAM_WEBHOOK_SECRET=

# Ваш personal chat_id в Telegram — только этому chat_id бот будет
# отвечать. Узнать: написать боту, посмотреть в логах контейнера
# (chat_id постороннего будет виден в WARNING-логе), либо через
# отдельного бота вроде @userinfobot.
OWNER_CHAT_ID=

# Путь для вебхука, по умолчанию /webhook — можно не менять.
TELEGRAM_WEBHOOK_PATH=/webhook

# Railway сам задаёт PORT — локально можно оставить как есть.
PORT=8080

# Нужен только для разового запуска scripts/set_webhook.py —
# публичный домен, который Railway выдаёт сервису (Settings → Networking).
PUBLIC_URL=
